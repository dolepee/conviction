{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self'; font-src 'self'; img-src 'self' data: blob:; connect-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|styles.css|app.js|wallet-setup\\.css|wallet-setup\\.js|wallet-setup\\.html|privacy\\.html|terms\\.html|robots\\.txt|manifest\\.webmanifest).*)",
      "destination": "/index.html"
    }
  ]
}
