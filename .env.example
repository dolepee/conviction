# Payment-enabled credentials from https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
CONVICTION_ISSUER_KEY_ID=
CONVICTION_ISSUER_PRIVATE_KEY_B64=
CONVICTION_ISSUER_PUBLIC_KEY_B64=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Server-only Polymarket authentication. Builder credentials are mandatory for
# creating Deposit Wallets for new buyers. A dedicated Relayer key is optional
# and may authorize operations only for its exact associated account. Never put
# any of these values in browser code, Git, x402 requests, or logs.
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=
# Browser Deposit Wallet setup remains inactive unless every setting below is
# supplied through server-only encrypted environment variables. The state URL
# and Polygon RPC must be fixed HTTPS endpoints; never use an in-memory store
# in a deployed environment.
CONVICTION_WALLET_SESSION_SECRET=
CONVICTION_WALLET_STATE_REST_URL=
CONVICTION_WALLET_STATE_REST_TOKEN=
# Vercel's Upstash integration may supply KV_REST_API_URL and
# KV_REST_API_TOKEN instead of the Conviction-specific aliases above.
KV_REST_API_URL=
KV_REST_API_TOKEN=
CONVICTION_POLYGON_RPC_URL=
